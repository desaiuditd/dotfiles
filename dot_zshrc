# START/oh-my-zsh
export ZSH="$HOME/.oh-my-zsh"

zstyle ':omz:update' mode reminder

zstyle ':omz:plugins:eza' 'git-status' yes
zstyle ':omz:plugins:eza' 'header' yes

plugins=(
  brew
  chezmoi
  docker
  docker-compose
  eza
  git
  golang
  helm
  kubectl
  npm
  task
  yarn
)

source $ZSH/oh-my-zsh.sh
# END/oh-my-zsh

# START/update PATH for other tools
export PATH="$PATH:$HOME/.local/bin"
export PATH="$HOME/.deno/bin:$PATH"
export PATH="${KREW_ROOT:-$HOME/.krew}/bin:$PATH"
export PATH="$(brew --prefix)/opt/libpq/bin:$PATH"
export PATH="$(brew --prefix)/opt/openjdk/bin:$PATH"
# END/update PATH for other tools

# START/init other tools
eval "$(mise activate zsh)"
eval "$(starship init zsh)"
eval "$(zoxide init zsh)"

if command -v ngrok &>/dev/null; then
  eval "$(ngrok completion)"
fi

if type brew &>/dev/null; then
  # zsh-completions
  FPATH=$(brew --prefix)/share/zsh-completions:$FPATH

  # autoload -Uz compinit
  # compinit
  source $(brew --prefix)/share/zsh-autocomplete/zsh-autocomplete.plugin.zsh
fi
# END/init other tools

if [ -f "$HOME/.zshrc.local" ]; then
  source "$HOME/.zshrc.local"
fi

# START/aliases
alias cz=chezmoi
alias cat=bat
alias kcx='kubectx'

# Git Aliases. Ref: https://piechowski.io/post/git-commands-before-reading-code/
# What Changes the Most
alias gcm='git log --format=format: --name-only --since="1 year ago" | sort | uniq -c | sort -nr | head -20'
# Who Built This
alias gwb='git shortlog -sn --no-merges'
# Where Do Bugs Cluster
alias gbc='git log -i -E --grep="fix|bug|broken" --name-only --format="" | sort | uniq -c | sort -nr | head -20'
# Is This Project Accelerating or Dying
alias gpad='git log --format="%ad" --date=format:"%Y-%m" | sort | uniq -c'
# How Often Is the Team Firefighting
alias gff='git log --oneline --since="1 year ago" | grep -iE "revert|hotfix|emergency|rollback"'
# END/aliases

# zsh-syntax-highlighting. MUST be last to load.
source $(brew --prefix)/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
